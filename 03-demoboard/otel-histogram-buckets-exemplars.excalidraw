      "locked": false,
      "text": "Exemplars are not added by a manual API call\n\nThe OTEL SDK can attach them automatically\nwhen record() happens while a span is active",
      "fontSize": 16,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "middle",
      "baseline": 92,
      "containerId": null,
      "originalText": "Exemplars are not added by a manual API call\n\nThe OTEL SDK can attach them automatically\nwhen record() happens while a span is active",
